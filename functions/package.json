{
  "name": "menux-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Menux - Security and Order Management",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "firebase emulators:start --only functions",
