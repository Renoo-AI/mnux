rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      // SECURITY: Only custom claims are used for superadmin verification.
      // No hardcoded UIDs in publicly-readable rules.
      // Server-side fallback (admin-auth.ts) uses SUPERADMIN_UID env var.
      return isAuthenticated() && request.auth.token.role == 'superadmin';
    }
    
    function isOwner(restaurantId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }
    
    function isStaff(restaurantId) {
      let restaurant = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      return isAuthenticated() && 
        (restaurant.ownerUid == request.auth.uid || 
         restaurant.staffUids[request.auth.uid] != null);
    }
    
    function isValidString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }
    
    function isValidPrice(price) {
      return price is number && price >= 0 && price <= 100000;
    }
    
    function sanitizeString(value) {
      return value.matches('^[-a-zA-Z0-9 ]*$');
    }
    
    // Check if restaurant is on free plan (supports both old and new plan formats)
    function isFreePlan(restaurantId) {
      let restaurant = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      return restaurant.plan == 'free' || restaurant.plan == 'FREE';
    }
    
    // Check if plan is valid (supports both old and new formats)
    function isValidPlan(plan) {
      return plan in ['free', 'pro', 'FREE', 'BASIC', 'PRO', 'MAX'];
    }
    
    // Check if plan is PRO or higher (can use advanced features)
    function isProOrHigher(restaurantId) {
      let restaurant = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      let plan = restaurant.plan;
      return plan == 'pro' || plan == 'PRO' || plan == 'MAX';
    }
    
    // Validate hex color format (#RRGGBB)
    function isValidHexColor(color) {
      return color == null || 
        (color is string && 
         color.size() == 7 && 
         color.matches('^#[0-9A-Fa-f]{6}$'));
    }
    
    // Validate branding theme colors
    function isValidTheme(theme) {
      return theme == null || (
        (theme.background == null || isValidHexColor(theme.background)) &&
        (theme.foreground == null || isValidHexColor(theme.foreground)) &&
        (theme.primary == null || isValidHexColor(theme.primary)) &&
        (theme.accent == null || isValidHexColor(theme.accent)) &&
        (theme.card == null || isValidHexColor(theme.card)) &&
        (theme.border == null || isValidHexColor(theme.border))
      );
    }
    
    // Validate branding object
    function isValidBranding(branding) {
      return branding == null || (
        // Validate URLs
        (branding.logoUrl == null || (branding.logoUrl is string && branding.logoUrl.size() <= 500)) &&
        (branding.coverImageUrl == null || (branding.coverImageUrl is string && branding.coverImageUrl.size() <= 500)) &&
        (branding.backgroundImageUrl == null || (branding.backgroundImageUrl is string && branding.backgroundImageUrl.size() <= 500)) &&
        (branding.faviconUrl == null || (branding.faviconUrl is string && branding.faviconUrl.size() <= 256)) &&
        // Validate theme
        isValidTheme(branding.theme) &&
        // Validate openGraph
        (branding.openGraph == null || 
          (branding.openGraph.title == null || branding.openGraph.title.size() <= 80) &&
          (branding.openGraph.description == null || branding.openGraph.description.size() <= 180) &&
          (branding.openGraph.imageUrl == null || branding.openGraph.imageUrl.size() <= 500)
        ) &&
        // Validate customCss
        (branding.customCss == null || 
          (branding.customCss.css == null || branding.customCss.css.size() <= 10000)
        )
      );
    }
    
    // Count current menu items for a restaurant (used for free plan limit)
    // Note: This is expensive - prefer using Cloud Functions for counting
    function countMenuItems(restaurantId) {
      return 0; // Placeholder - actual counting requires Cloud Functions
    }
    
    // Free plan menu item limit (max 8 items)
    function FREE_PLAN_ITEM_LIMIT() {
      return 8;
    }

    // ============================================
    // RESTAURANTS
    // ============================================
    match /restaurants/{restaurantId} {
      // 1. Public can read public restaurant/menu data (ACTIVE restaurants)
      allow read: if resource.data.status == 'ACTIVE' || isStaff(restaurantId) || isSuperAdmin();
      
      // Authenticated users can create restaurants (for free plan signup)
      allow create: if isAuthenticated() 
        && isValidString(resource.data.name, 100)
        && isValidString(resource.data.slug, 50)
        && resource.data.status == 'ACTIVE'
        && resource.data.ownerUid == request.auth.uid
        && isValidPlan(resource.data.plan)
        && isValidBranding(resource.data.branding);
      
      // 6. Owner can edit own restaurant (with plan restriction enforcement)
      // SECURITY: Owners CANNOT modify these fields:
      // - plan (must go through superadmin)
      // - maxMenuItems (must go through superadmin)
      // - menuItemCount (managed by system only)
      // - watermarkEnabled (forced true for free plan)
      // - slugType (forced 'free-random' for free plan)
      // - slug (only superadmin can change)
      // - branding must be valid
      allow update: if (isOwner(restaurantId) || isSuperAdmin())
        // Owners on free plan cannot disable watermark
        && (isSuperAdmin() || 
            resource.data.plan != 'free' || 
            request.resource.data.watermarkEnabled == true)
        // Owners cannot change plan field
        && (isSuperAdmin() || 
            request.resource.data.plan == resource.data.plan)
        // Owners cannot change maxMenuItems
        && (isSuperAdmin() || 
            request.resource.data.maxMenuItems == resource.data.maxMenuItems)
        // Owners cannot change menuItemCount directly
        && (isSuperAdmin() || 
            request.resource.data.menuItemCount == resource.data.menuItemCount)
        // Validate branding if provided
        && isValidBranding(request.resource.data.branding)
        // Only allow specific fields to be updated by owner
        && (isSuperAdmin() || 
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'name', 'cuisineType', 'address', 'phone', 'email', 
              'openingHours', 'branding', 'updatedAt'
            ]));
      
      // Only superadmin can delete
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // TABLES
    // ============================================
    match /tables/{tableId} {
      // 1. Public can read tables for ACTIVE restaurants
      allow read: if resource.data.restaurantId != null && 
        (get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.status == 'ACTIVE' ||
         isStaff(resource.data.restaurantId) || 
         isSuperAdmin());
      
      // 4. Public cannot edit tables - only staff/superadmin can create
      allow create: if isAuthenticated() && 
        (isStaff(resource.data.restaurantId) || isSuperAdmin())
        && isValidString(resource.data.name, 10);
      
      // Staff can update tables
      allow update: if isStaff(resource.data.restaurantId) || isSuperAdmin();
      
      // Staff can delete tables
      allow delete: if isStaff(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // CATEGORIES
    // ============================================
    match /categories/{categoryId} {
      // 1. Public can read categories for ACTIVE restaurants
      allow read: if resource.data.restaurantId != null && 
        (get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.status == 'ACTIVE' ||
         isStaff(resource.data.restaurantId) || 
         isSuperAdmin());
      
      // 3. Public cannot edit menu (categories are part of menu) - staff only
      allow create, update, delete: if isStaff(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // MENU ITEMS
    // ============================================
    // Helper to check menu item limit for free plan
    // Uses menuItemCount counter maintained by API routes
    function isWithinMenuItemLimit(restaurantId) {
      let restaurant = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      // PRO/MAX plans have unlimited items
      if (restaurant.plan == 'pro' || restaurant.plan == 'PRO' || restaurant.plan == 'MAX') {
        return true;
      }
      // Free/Basic plan: check current count against maxMenuItems (default 8)
      let maxItems = restaurant.maxMenuItems != null ? restaurant.maxMenuItems : 8;
      let currentCount = restaurant.menuItemCount != null ? restaurant.menuItemCount : 0;
      return currentCount < maxItems;
    }
    
    // IMPORTANT: Collection name is 'menuItems' (camelCase) to match API
    match /menuItems/{itemId} {
      // 1. Public can read menu items for ACTIVE restaurants
      allow read: if resource.data.restaurantId != null && 
        (get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.status == 'ACTIVE' ||
         isStaff(resource.data.restaurantId) || 
         isSuperAdmin());
      
      // 3. Public cannot edit menu items - staff only with validation
      // 11. Free plan item limit (max 8 items) - enforced via menuItemCount counter
      // The counter is maintained by API routes on create/delete operations
      allow create: if (isStaff(resource.data.restaurantId) || isSuperAdmin())
        && isValidString(resource.data.name, 100)
        && isValidPrice(resource.data.price)
        && isWithinMenuItemLimit(resource.data.restaurantId);
      
      allow update: if (isStaff(resource.data.restaurantId) || isSuperAdmin())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'price', 'imageUrl', 'available', 'isFeatured', 'tags', 'allergens', 'sortOrder', 'categoryId', 'updatedAt']);
      
      allow delete: if isStaff(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // ORDERS
    // ============================================
    match /orders/{orderId} {
      // Staff can read orders for their restaurant
      allow read: if resource.data.restaurantId != null && (
        (isAuthenticated() && isStaff(resource.data.restaurantId)) ||
        isSuperAdmin()
      );
      
      // 5. Public can create a valid order
      // Note: Order creation from unauthenticated users (via QR codes)
      allow create: if isValidString(resource.data.restaurantId, 128)
        && resource.data.status == 'CREATED'
        && isValidPrice(resource.data.totalAmount)
        && resource.data.items is list
        && resource.data.items.size() > 0
        && resource.data.items.size() <= 50;
      
      // 8. Staff can update order for own restaurant
      // 9. Staff cannot update another restaurant order (enforced by isStaff check)
      allow update: if (isStaff(resource.data.restaurantId) || isSuperAdmin())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'acceptedAt', 'paidAt', 'closedAt', 'cancelledAt', 'rejectReason', 'cancelReason']);
      
      // Only superadmin can delete orders
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // LOGS (Activity logs)
    // ============================================
    match /logs/{logId} {
      // Staff can read logs for their restaurant
      allow read: if isAuthenticated() && 
        (isStaff(resource.data.restaurantId) || isSuperAdmin());
      
      // System can create logs
      allow create: if true;
      
      // Logs are immutable
      allow update, delete: if false;
    }
    
    // ============================================
    // STAFF
    // ============================================
    match /staff/{staffId} {
      // Staff can read other staff in their restaurant
      allow read: if isAuthenticated() && (
        (resource.data.restaurantId != null && isStaff(resource.data.restaurantId)) ||
        isSuperAdmin()
      );
      
      // Owner can manage staff
      allow create, update: if isOwner(resource.data.restaurantId) || isSuperAdmin();
      
      // Only owner can delete staff
      allow delete: if isOwner(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // USERS
    // ============================================
    match /users/{userId} {
      // Users can read and update their own profile
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can create their own profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Only superadmin can delete users
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // BANNED USERS (SuperAdmin data)
    // ============================================
    match /banned_users/{userId} {
      // 10. Non-superadmin cannot access superadmin data
      allow read, write: if isSuperAdmin();
    }
    
    // ============================================
    // MAGIC LINKS
    // ============================================
    match /magic_links/{tokenId} {
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        isSuperAdmin()
      );
      
      allow create: if isSuperAdmin();
      allow update: if isAuthenticated() && resource.data.isUsed == false;
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // SYSTEM LOGS (SuperAdmin data)
    // ============================================
    match /system_logs/{logId} {
      // 10. Non-superadmin cannot access superadmin data
      allow read: if isSuperAdmin();
      
      // System can create logs
      allow create: if true;
      
      // Logs are immutable
      allow update, delete: if false;
    }
    
    // ============================================
    // RATE LIMITING
    // ============================================
    match /rate_limits/{rateLimitId} {
      allow read, write: if false; // Managed by Cloud Functions only
    }
    
    // ============================================
    // BANNED IPS (SuperAdmin security)
    // ============================================
    match /banned_ips/{ipId} {
      // Only superadmin can read/write
      allow read, write: if isSuperAdmin();
    }
    
    // ============================================
    // BANNED DEVICES (SuperAdmin security)
    // ============================================
    match /banned_devices/{deviceId} {
      // Only superadmin can read/write
      allow read, write: if isSuperAdmin();
    }
    
    // ============================================
    // SECURITY EVENTS (Audit trail)
    // ============================================
    match /security_events/{eventId} {
      // System can create events (from API routes)
      allow create: if true;
      // Only superadmin can read
      allow read: if isSuperAdmin();
      // Events are immutable
      allow update, delete: if false;
    }
    
    // ============================================
    // TABLE REQUESTS (CALL_WAITER, REQUEST_BILL)
    // ============================================
    match /table_requests/{requestId} {
      // Staff can read requests for their restaurant
      allow read: if isAuthenticated() && (
        (resource.data.restaurantId != null && isStaff(resource.data.restaurantId)) ||
        isSuperAdmin()
      );
      
      // Public can create requests with validation
      allow create: if isValidString(resource.data.restaurantId, 128)
        && isValidString(resource.data.tableId, 128)
        && resource.data.type in ['CALL_WAITER', 'REQUEST_BILL']
        && resource.data.status == 'PENDING'
        // Validate required fields
        && resource.data.createdAt != null
        && resource.data.updatedAt != null;
      
      // Staff can update (acknowledge, resolve)
      allow update: if isAuthenticated() && (
        (resource.data.restaurantId != null && isStaff(resource.data.restaurantId)) ||
        isSuperAdmin()
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status', 'acknowledgedAt', 'acknowledgedBy', 'resolvedAt', 'resolvedBy', 'updatedAt'
      ]);
      
      // Only superadmin can delete
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // REVIEWS (Customer feedback)
    // ============================================
    match /reviews/{reviewId} {
      // Public can read reviews for active restaurants
      allow read: if resource.data.restaurantId != null && (
        get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.status == 'ACTIVE' ||
        isStaff(resource.data.restaurantId) ||
        isSuperAdmin()
      );
      
      // Public can create review with validation
      allow create: if isValidString(resource.data.restaurantId, 128)
        && isValidString(resource.data.orderId, 128)
        && resource.data.rating is int
        && resource.data.rating >= 1
        && resource.data.rating <= 5
        && (resource.data.comment == null || 
            (resource.data.comment is string && resource.data.comment.size() <= 500))
        && resource.data.createdAt != null;
      
      // No updates allowed (reviews are immutable)
      allow update: if false;
      
      // Only superadmin can delete
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // RESTAURANT BANS (Per-restaurant security)
    // ============================================
    match /restaurants/{restaurantId}/securityBans/{banId} {
      // Staff can read bans for their restaurant
      allow read: if isStaff(restaurantId) || isSuperAdmin();
      
      // Only owner/superadmin can create bans
      allow create: if isOwner(restaurantId) || isSuperAdmin();
      
      // Only owner/superadmin can update bans
      allow update: if isOwner(restaurantId) || isSuperAdmin();
      
      // Only owner/superadmin can delete bans
      allow delete: if isOwner(restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // ABUSE COUNTERS (Rate limit tracking)
    // ============================================
    match /restaurants/{restaurantId}/abuseCounters/{counterId} {
      // Only system/API routes can read/write (no direct client access)
      allow read, write: if false;
    }
    
    // ============================================
    // DENY ALL OTHER (Default Deny)
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
