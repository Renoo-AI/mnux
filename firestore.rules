rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.uid == superAdminUid();
    }
    
    function superAdminUid() {
      // This should match your NEXT_PUBLIC_SUPERADMIN_UID
      // In production, consider using Firebase Custom Claims instead
      return 'rjAbnlO0deNZRavuHgfBsxRZTVY2';
    }
    
    function isOwner(restaurantId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }
    
    function isStaff(restaurantId) {
      let restaurant = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      return isAuthenticated() && 
        (restaurant.ownerUid == request.auth.uid || 
         restaurant.staffUids[request.auth.uid] != null);
    }
    
    function isValidString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }
    
    function isValidPrice(price) {
      return price is number && price >= 0 && price <= 100000;
    }

    // ============================================
    // RESTAURANTS
    // ============================================
    match /restaurants/{restaurantId} {
      // Public read for active restaurants (for menu display)
      // Note: Using 'ACTIVE' instead of 'active' to match the type
      allow read: if resource.data.status == 'ACTIVE' || isStaff(restaurantId) || isSuperAdmin();
      
      // Only superadmin can create restaurants
      allow create: if isSuperAdmin();
      
      // Owner or superadmin can update
      allow update: if isOwner(restaurantId) || isSuperAdmin();
      
      // Only superadmin can delete
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // TABLES (top-level collection)
    // ============================================
    match /tables/{tableId} {
      // Public read for active restaurant tables
      allow read: if resource.data.restaurantId != null && 
        (get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.status == 'ACTIVE' ||
         isStaff(resource.data.restaurantId) || 
         isSuperAdmin());
      
      // Staff can create/update tables for their restaurant
      allow create: if isStaff(resource.data.restaurantId) || isSuperAdmin();
      allow update: if isStaff(resource.data.restaurantId) || isSuperAdmin();
      allow delete: if isStaff(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // CATEGORIES (top-level collection)
    // ============================================
    match /categories/{categoryId} {
      // Public read for active restaurant categories
      allow read: if resource.data.restaurantId != null && 
        (get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.status == 'ACTIVE' ||
         isStaff(resource.data.restaurantId) || 
         isSuperAdmin());
      
      allow create, update, delete: if isStaff(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // MENU ITEMS (top-level collection)
    // ============================================
    match /menuItems/{itemId} {
      // Public read for active restaurant menu items
      allow read: if resource.data.restaurantId != null && 
        (get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.status == 'ACTIVE' ||
         isStaff(resource.data.restaurantId) || 
         isSuperAdmin());
      
      allow create, update: if isStaff(resource.data.restaurantId) || isSuperAdmin()
        && isValidString(resource.data.name, 100)
        && isValidPrice(resource.data.price);
      
      allow delete: if isStaff(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // ORDERS
    // ============================================
    match /orders/{orderId} {
      // Staff can read orders for their restaurant
      // Allow public read for order confirmation pages (with orderId in URL)
      allow read: if resource.data.restaurantId != null && (
        isAuthenticated() && isStaff(resource.data.restaurantId) ||
        isSuperAdmin()
      );
      
      // Orders are created via client SDK (with validation)
      // Note: For production, use Cloud Functions for order creation
      allow create: if isValidString(resource.data.restaurantId, 128)
        && resource.data.status == 'CREATED'
        && isValidPrice(resource.data.totalAmount)
        && resource.data.items is list;
      
      // Status updates - staff only, with field restrictions
      allow update: if isStaff(resource.data.restaurantId) || isSuperAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'updatedBy', 'acceptedAt', 'completedAt', 'cancelledAt', 'paidAt', 'closedAt', 'rejectReason', 'cancelReason']);
      
      // Only superadmin can delete orders (for cleanup)
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // LOGS (Activity logs per restaurant)
    // ============================================
    match /logs/{logId} {
      // Staff can read logs for their restaurant
      allow read: if isAuthenticated() && 
        (isStaff(resource.data.restaurantId) || isSuperAdmin());
      
      // Staff and system can create logs
      allow create: if isAuthenticated();
      
      // Logs are immutable
      allow update, delete: if false;
    }
    
    // ============================================
    // USERS
    // ============================================
    match /users/{userId} {
      // Users can read and update their own profile
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can create their own profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Only superadmin can delete users
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // BANNED USERS (Security)
    // ============================================
    match /banned_users/{userId} {
      // Only superadmin can manage banned users
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }
    
    // ============================================
    // MAGIC LINKS
    // ============================================
    match /magic_links/{tokenId} {
      // Magic links are one-time use, self-destruct after use
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        isSuperAdmin()
      );
      
      allow create: if isSuperAdmin();
      allow update: if isAuthenticated() && resource.data.isUsed == false;
      allow delete: if isSuperAdmin();
    }
    
    // ============================================
    // SYSTEM LOGS (Audit Trail)
    // ============================================
    match /system_logs/{logId} {
      // Only superadmin can read logs
      allow read: if isSuperAdmin();
      
      // Anyone authenticated can create logs (for audit trail)
      allow create: if isAuthenticated();
      
      // Logs are immutable
      allow update, delete: if false;
    }
    
    // ============================================
    // RATE LIMITING (Security)
    // ============================================
    match /rate_limits/{rateLimitId} {
      allow read, write: if false; // Managed by Cloud Functions only
    }
    
    // ============================================
    // DEVICE SECURITY
    // ============================================
    match /kicked_devices/{deviceId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    match /banned_devices/{deviceId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    // ============================================
    // STAFF (per restaurant)
    // ============================================
    match /staff/{staffId} {
      allow read: if isAuthenticated() && (
        resource.data.restaurantId != null && isStaff(resource.data.restaurantId) ||
        isSuperAdmin()
      );
      allow create, update, delete: if isOwner(resource.data.restaurantId) || isSuperAdmin();
    }
    
    // ============================================
    // DENY ALL OTHER (Default Deny)
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
