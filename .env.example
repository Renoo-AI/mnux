# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only - NEVER expose this in client code)
# Get from: Supabase Dashboard > Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Default Restaurant ID (optional - for the owner dashboard)
NEXT_PUBLIC_RESTAURANT_ID=your-restaurant-uuid-here
